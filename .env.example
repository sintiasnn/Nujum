# Google Gemini API Key
# Dapatkan gratis di: https://aistudio.google.com (free tier, tanpa billing)
GEMINI_API_KEY=your_gemini_api_key_here

# Model Gemini (opsional). Default: gemini-flash-latest
# Alternatif: gemini-2.5-flash
GEMINI_MODEL=gemini-flash-latest

# FastAPI Backend URL (default localhost)
API_BASE_URL=http://localhost:8000

# Environment (development / production)
ENV=development
